{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    "ConnectionStrings": {
        "DefaultConnection": "Server=.;Database=KarateClubDB;User Id=sa;Password=sa123456;Integrated security=true;TrustServerCertificate=True;"
    },

    "Jwt": {
        "Key": "a1b2c3d4e5f67890ghijklmnopqrstuvwx0123456789yzaBCDEFGHIJKLMN",
        "Issuer": "KrateClub.Api",
